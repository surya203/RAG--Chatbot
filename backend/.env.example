DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/rag_chatbot
SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173

# Groq API key (gsk_...) for LLM chat completions
API_KEY=your-groq-api-key
# OpenAI API key, used only for embeddings (text-embedding-3-small)
OPENAI_API_KEY=your-openai-api-key
# Optional overrides
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=text-embedding-3-small
